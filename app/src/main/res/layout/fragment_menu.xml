<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_bg"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="42dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/tvBakeryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍰 Sweet Crumbs Bakery"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/chocolate" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Freshly baked delights every day"
            android:textSize="15sp"
            android:textColor="@color/muted_brown"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvCartCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cart Items: 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/dark_cocoa"
        android:background="@color/section_bg"
        android:padding="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMenuProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnViewCart"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="View Cart"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_margin="16dp" />

</LinearLayout>