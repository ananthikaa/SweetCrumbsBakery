<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/soft_caramel"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCartProduct"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCartName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Croissant"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dark_cocoa" />

            <TextView
                android:id="@+id/tvCartPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="₹120 × 1"
                android:textSize="14sp"
                android:textColor="@color/caramel"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCartMinus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="-"
                android:textSize="16sp"
                android:padding="0dp" />

            <TextView
                android:id="@+id/tvCartQty"
                android:layout_width="32dp"
                android:layout_height="34dp"
                android:text="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/chocolate"
                android:gravity="center" />

            <Button
                android:id="@+id/btnCartPlus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="+"
                android:textSize="16sp"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>