<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_bg"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="42dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒 Your Cart"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/chocolate" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Review your bakery treats before billing"
            android:textSize="15sp"
            android:textColor="@color/muted_brown"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvOfferNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎁 Add items worth ₹1000 or more to get 10% off"
        android:textSize="14sp"
        android:textColor="@color/dark_cocoa"
        android:background="@color/section_bg"
        android:padding="12dp"
        android:layout_marginTop="14dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <Button
        android:id="@+id/btnProceedBill"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Proceed to Billing"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_margin="16dp" />

</LinearLayout>